# в”Ђв”Ђ Parse worktrees в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
declare -a WT_PATHS WT_BRANCHES WT_HEADS WT_IS_MAIN
declare -A WT_CATEGORY WT_REASON WT_LAST_DATE WT_SIZE

parse_worktrees() {
  local path="" branch="" head="" is_bare=false is_main_wt=false idx=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == worktree\ * ]]; then
      if [[ -n "$path" ]] && ! $is_bare; then
        WT_PATHS[$idx]="$path"
        WT_BRANCHES[$idx]="${branch:-detached}"
        WT_HEADS[$idx]="${head:-}"
        WT_IS_MAIN[$idx]="$is_main_wt"
        (( idx++ )) || true
      fi
      path="${line#worktree }"
      branch=""
      head=""
      is_bare=false
      is_main_wt=false
    elif [[ "$line" == "HEAD "* ]]; then
      head="${line#HEAD }"
    elif [[ "$line" == "branch "* ]]; then
      branch="${line#branch refs/heads/}"
      # Normalise -- could be refs/remotes/... or detached
      branch="${branch#refs/remotes/}"
    elif [[ "$line" == "bare" ]]; then
      is_bare=true
    elif [[ "$line" == "prunable" ]]; then
      true
    fi
  done < <(git worktree list --porcelain; echo)

  # Last block (no trailing newline guard)
  if [[ -n "$path" ]] && ! $is_bare; then
    WT_PATHS[$idx]="$path"
    WT_BRANCHES[$idx]="${branch:-detached}"
    WT_HEADS[$idx]="${head:-}"
    WT_IS_MAIN[$idx]="$is_main_wt"
  fi

  # Mark the main worktree (the one matching MAIN_WT)
  for i in "${!WT_PATHS[@]}"; do
    if [[ "${WT_PATHS[$i]}" == "$MAIN_WT" ]]; then
      WT_IS_MAIN[$i]=true
    fi
  done
}

parse_worktrees

# в”Ђв”Ђ Merged branches set в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
declare -A MERGED_BRANCHES GONE_BRANCHES

build_merged_set() {
  # Standard merge
  while IFS= read -r b; do
    b="${b#  }"; b="${b#* }"  # strip leading spaces and '*'
    b="${b// /}"
    [[ -n "$b" ]] && MERGED_BRANCHES["$b"]=1
  done < <(git branch --merged "$DEFAULT_BRANCH" 2>/dev/null || true)

  # Remote-gone branches
  while IFS= read -r line; do
    if [[ "$line" =~ \[.*:\ gone\] ]]; then
      local bname
      bname="$(echo "$line" | sed 's/^[[:space:]]*[*+][[:space:]]*//' | awk '{print $1}')"
      GONE_BRANCHES["$bname"]=1
    fi
  done < <(git branch -vv 2>/dev/null || true)
}

build_merged_set

# в”Ђв”Ђ Squash-merge detection в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
is_squash_merged() {
  local branch="$1"
  local default="$2"
  # Create a temporary commit of the branch's tree rebased onto the merge-base
  # then check if git cherry finds it already in default
  local merge_base
  merge_base="$(git merge-base "$default" "$branch" 2>/dev/null)" || return 1
  # If merge_base == HEAD of branch, it's a fast-forward (already merged)
  local branch_head
  branch_head="$(git rev-parse "$branch" 2>/dev/null)" || return 1
  if [[ "$merge_base" == "$branch_head" ]]; then
    return 0
  fi
  # Build a temp commit with the same tree as branch but parented on merge-base
  local temp_commit
  temp_commit="$(git commit-tree "$branch^{tree}" -p "$merge_base" -m "squash-merge-check" 2>/dev/null)" || return 1
  # cherry returns lines prefixed with '-' if equivalent commit exists in default
  local cherry_out
  cherry_out="$(git cherry "$default" "$temp_commit" 2>/dev/null)" || return 1
  [[ "$cherry_out" == -* ]]
}

# в”Ђв”Ђ Stale date check в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
stale_cutoff_epoch() {
  if date -v "-${STALE_DAYS}d" +%s >/dev/null 2>&1; then
    date -v "-${STALE_DAYS}d" +%s  # macOS BSD date
  else
    date -d "-${STALE_DAYS} days" +%s  # GNU date
  fi
}

STALE_CUTOFF="$(stale_cutoff_epoch)"

last_commit_epoch() {
  local branch="$1"
  git log -1 --format="%ct" "$branch" 2>/dev/null || echo "0"
}

# в”Ђв”Ђ Classify worktrees в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
classify_worktrees() {
  local total="${#WT_PATHS[@]}"
  info "Analysing ${total} worktree(s)..."
  echo ""
  for i in "${!WT_PATHS[@]}"; do
    local path="${WT_PATHS[$i]}"
    local branch="${WT_BRANCHES[$i]}"
    local is_main="${WT_IS_MAIN[$i]}"

    if $is_main || [[ "$branch" == "$DEFAULT_BRANCH" ]]; then
      WT_CATEGORY[$i]="main"
      WT_REASON[$i]="main worktree"
      WT_LAST_DATE[$i]=""
      WT_SIZE[$i]=""
      continue
    fi

    # Disk size
    local size
    size="$(du -sh "$path" 2>/dev/null | cut -f1)" || size="?"
    WT_SIZE[$i]="$size"

    # Last commit date
    local last_epoch=0 last_date=""
    if [[ "$branch" != "detached" ]]; then
      last_epoch="$(last_commit_epoch "$branch")"
      last_date="$(git log -1 --format="%ci" "$branch" 2>/dev/null | cut -d' ' -f1)" || last_date="?"
    elif [[ -n "${WT_HEADS[$i]}" ]]; then
      last_epoch="$(last_commit_epoch "${WT_HEADS[$i]}")"
      last_date="$(git log -1 --format="%ci" "${WT_HEADS[$i]}" 2>/dev/null | cut -d' ' -f1)" || last_date="?"
    fi
    WT_LAST_DATE[$i]="${last_date:-?}"

    # Category detection
    if [[ "$branch" != "detached" ]]; then
      if [[ -n "${MERGED_BRANCHES[$branch]+x}" ]]; then
        WT_CATEGORY[$i]="merged"
        WT_REASON[$i]="merged into ${DEFAULT_BRANCH}"
      elif [[ -n "${GONE_BRANCHES[$branch]+x}" ]]; then
        WT_CATEGORY[$i]="merged"
        WT_REASON[$i]="remote branch deleted"
      elif is_squash_merged "$branch" "$DEFAULT_BRANCH" 2>/dev/null; then
        WT_CATEGORY[$i]="merged"
        WT_REASON[$i]="squash-merged into ${DEFAULT_BRANCH}"
      elif [[ "$last_epoch" -lt "$STALE_CUTOFF" ]]; then
        WT_CATEGORY[$i]="stale"
        WT_REASON[$i]="no commits in ${STALE_DAYS}+ days"
      else
        WT_CATEGORY[$i]="active"
        WT_REASON[$i]=""
      fi
    else
      WT_CATEGORY[$i]="detached"
      if [[ "$last_epoch" -lt "$STALE_CUTOFF" ]] && [[ "$last_epoch" -ne 0 ]]; then
        WT_REASON[$i]="detached HEAD, no commits in ${STALE_DAYS}+ days"
      else
        WT_REASON[$i]="detached HEAD"
      fi
    fi
  done
}

classify_worktrees

# в”Ђв”Ђ Count categories в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
