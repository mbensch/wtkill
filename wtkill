# в”Ђв”Ђ Display в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
display_section() {
  local cat="$1" label="$2" colour="$3" count="$4"
  [[ "$count" -eq 0 ]] && return
  echo -e "${colour}${BOLD}в—Џ ${label}${RESET}"
  # shellcheck disable=SC2034
  local col_path=40 col_branch=30 col_date=12 col_size=8
  printf "${DIM}  %-${col_path}s  %-${col_branch}s  %-${col_date}s  %s${RESET}\n" \
    "PATH" "BRANCH" "LAST COMMIT" "SIZE"
  for i in "${!WT_PATHS[@]}"; do
    [[ "${WT_CATEGORY[$i]}" != "$cat" ]] && continue
    local path="${WT_PATHS[$i]}" branch="${WT_BRANCHES[$i]}"
    local date="${WT_LAST_DATE[$i]:-?}" size="${WT_SIZE[$i]:-?}"
    local reason="${WT_REASON[$i]}"
    local short_path="$path"
    # Shorten home prefix
    short_path="${short_path/#$HOME/~}"
    # Truncate if needed
    if [[ "${#short_path}" -gt "$col_path" ]]; then
      short_path="вЂ¦${short_path: -$((col_path-1))}"
    fi
    if [[ "${#branch}" -gt "$col_branch" ]]; then
      branch="${branch:0:$((col_branch-1))}вЂ¦"
    fi
    printf "  ${colour}%-${col_path}s${RESET}  ${BOLD}%-${col_branch}s${RESET}  ${DIM}%-${col_date}s  %s${RESET}" \
      "$short_path" "$branch" "$date" "$size"
    if [[ -n "$reason" ]]; then
      echo -e "  ${DIM}[${reason}]${RESET}"
    else
      echo ""
    fi
  done
  echo ""
}

echo -e "${BOLD}Found ${total_workrees} worktree(s):${RESET}  ${BOLD_GREEN}${count_merged} merged${RESET}  ${BOLD_YELLOW}${count_stale} stale${RESET}  ${BOLD_RED}${count_detached} detached${RESET}  ${BOLD_WHITE}${count_active} active${RESET}"
echo ""

display_section "merged"   "MERGED вЂ” safe to remove" "$BOLD_GREEN" "$count_merged"
display_section "stale"    "STALE вЂ” no updates in ${STALE_DAYS}+ days" "$BOLD_YELLOW" "$count_stale"
display_section "detached" "DETACHED вЂ” no branch, likely orphaned" "$BOLD_RED" "$count_detached"
display_section "active"   "ACTIVE" "$BOLD_WHITE" "$count_active"

if $REPORT_ONLY; then
  exit 0
fi

# в”Ђв”Ђ Helper: collect paths by category в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
paths_for_categories() {
  local -a result=()
  for cat in "$@"; do
    for i in "${!WT_PATHS[@]}"; do
      [[ "${WT_CATEGORY[$i]}" == "$cat" ]] && result+=("${WT_PATHS[$i]}")
    done
  done
  printf '%s\n' "${result[@]}"
}

# в”Ђв”Ђ Helper: human-readable total size в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
total_size_for_categories() {
  local paths
  paths="$(paths_for_categories "$@")"
  [[ -z "$paths" ]] && echo "0B" && return
  # Filter to existing paths only, suppress errors for missing ones
  local existing
  existing="$(echo "$paths" | while IFS= read -r p; do [[ -d "$p" ]] && echo "$p"; done)"
  [[ -z "$existing" ]] && echo "?" && return
  echo "$existing" | tr '\n' '\0' | xargs -0 du -sch 2>/dev/null | tail -1 | cut -f1 || echo "?"
}

# в”Ђв”Ђ Remove worktrees в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
remove_worktrees() {
  local -a targets=("$@")
  local removed=0
  for path in "${targets[@]}"; do
    echo -e "  ${DIM}removing ${path}вЂ¦${RESET}"
    if $DRY_RUN; then
      echo -e "  ${YELLOW}[dry-run] would run: git worktree remove --force \"${path}\"${RESET}"
    else
      git worktree remove --force "$path" 2>/dev/null \
        || { echo -e "  ${RED}failed to remove ${path}${RESET}"; continue; }
    fi
    (( removed++ )) || true
  done
  echo ""
  if $DRY_RUN; then
    info "[dry-run] would run: git worktree prune"
  else
    info "Running git worktree prune..."
    git worktree prune
  fi
  echo ""
  echo -e "${BOLD_GREEN}  Done! Removed ${removed} worktree(s).${RESET}"
}

# в”Ђв”Ђ Action menu в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# Toggle state: merged pre-selected as it's always safe
sel_merged=false
sel_stale=false
sel_detached=false
sel_active=false
[[ "$count_merged" -gt 0 ]] && sel_merged=true

# Restore cursor on exit
trap 'tput cnorm 2>/dev/null || true' EXIT

# Read a single keypress; sets KEY to the logical key name
read_key() {
  local ch
  IFS= read -rsn1 ch
  if [[ "$ch" == $'\x1b' ]]; then
    local seq1 seq2
    IFS= read -rsn1 -t 0.1 seq1 || true
    IFS= read -rsn1 -t 0.1 seq2 || true
    case "${seq1}${seq2}" in
      '[A') KEY="up"    ;;
      '[B') KEY="down"  ;;
      *)    KEY="esc"   ;;
    esac
  elif [[ "$ch" == '' ]]; then
    KEY="enter"
  elif [[ "$ch" == ' ' ]]; then
    KEY="space"
  else
    KEY="$ch"
  fi
}

MENU_LINES=0

# Render the TUI menu in-place.
# Args: $1 = current highlighted row (0-3)
render_menu_tui() {
  local pos="$1"
  local -a labels=("Merged" "Stale" "Detached" "Active")
  local -a counts=("$count_merged" "$count_stale" "$count_detached" "$count_active")
  local -a colours=("$BOLD_GREEN" "$BOLD_YELLOW" "$BOLD_RED" "$BOLD_WHITE")
  local -a sels=("$sel_merged" "$sel_stale" "$sel_detached" "$sel_active")
  local -a sizes=("$sz_merged" "$sz_stale" "$sz_detached" "$sz_active")
  local lines=0

  # Move cursor up to overwrite previous render, then erase to end of screen
  if [[ "$MENU_LINES" -gt 0 ]]; then
    echo -en "\033[${MENU_LINES}A"
  fi
  echo -en '\033[J'

  echo -e "${BOLD}Select categories to remove:${RESET}"; (( lines++ )) || true
  echo -e "${DIM}  в†‘/в†“ or j/k to move  Space to toggle  Enter to confirm  i for fzf  q to quit${RESET}"; (( lines++ )) || true
  echo ""; (( lines++ )) || true

  for row in 0 1 2 3; do
    local colour="${colours[$row]}"
    local label="${labels[$row]}"
    local count="${counts[$row]}"
    local sel="${sels[$row]}"
    local sz="${sizes[$row]}"
    local cursor_mark="  "
    [[ "$row" -eq "$pos" ]] && cursor_mark="${BOLD_CYAN}> ${RESET}"
    if [[ "$count" -gt 0 ]]; then
      local mark; $sel && mark="${colour}[x]${RESET}" || mark="[ ]"
      local line="${cursor_mark}${mark} ${colour}${label}${RESET}"
      [[ "$row" -eq "$pos" ]] && line="${cursor_mark}${mark} ${BOLD}${colour}${label}${RESET}"
      echo -e "  ${line}  ${DIM}${count} worktree(s), ~${sz}${RESET}"; (( lines++ )) || true
    else
      echo -e "  ${cursor_mark}${DIM}[ ] ${label}  вЂ” none found${RESET}"; (( lines++ )) || true
    fi
  done

  echo ""; (( lines++ )) || true
  echo -e "  ${BOLD_CYAN}[i]${RESET} Select individual worktrees  ${DIM}(fzf)${RESET}   ${DIM}[q] Quit${RESET}"; (( lines++ )) || true

  if $DRY_RUN; then
    echo ""; (( lines++ )) || true
    echo -e "  ${YELLOW}${BOLD}[dry-run mode active вЂ” no files will be deleted]${RESET}"; (( lines++ )) || true
  fi
  echo ""; (( lines++ )) || true

  MENU_LINES=$lines
}

# Returns the index of the next navigable row (count > 0), wrapping around
next_navigable() {
  local current="$1" dir="$2"
  local -a counts=("$count_merged" "$count_stale" "$count_detached" "$count_active")
  local candidate="$current"
  for _ in 0 1 2 3; do
    candidate=$(( (candidate + dir + 4) % 4 ))
    if [[ "${counts[$candidate]}" -gt 0 ]]; then
      echo "$candidate"
      return
    fi
  done
  echo "$current"
}

toggle_row() {
  local row="$1"
  case "$row" in
    0) $sel_merged   && sel_merged=false   || sel_merged=true   ;;
    1) $sel_stale    && sel_stale=false    || sel_stale=true     ;;
    2) $sel_detached && sel_detached=false || sel_detached=true  ;;
    3) $sel_active   && sel_active=false   || sel_active=true    ;;
  esac
}

tui_menu() {
  # Find the first navigable row
  local pos=0
  local -a counts=("$count_merged" "$count_stale" "$count_detached" "$count_active")
  local found=false
  for i in 0 1 2 3; do
    if [[ "${counts[$i]}" -gt 0 ]]; then
      pos=$i
      found=true
      break
    fi
  done

  if ! $found; then
    echo -e "  ${DIM}No removable worktrees found.${RESET}"
    exit 0
  fi

  # Pre-compute sizes once so render_menu_tui doesn't call du on every keypress
  sz_merged="$(total_size_for_categories merged)"
  sz_stale="$(total_size_for_categories stale)"
  sz_detached="$(total_size_for_categories detached)"
  sz_active="$(total_size_for_categories active)"

  hr
  echo ""
  tput civis 2>/dev/null || true
  render_menu_tui "$pos"

  while true; do
    read_key
    case "$KEY" in
      up|k)
        pos="$(next_navigable "$pos" -1)"
        render_menu_tui "$pos"
        ;;
      down|j)
        pos="$(next_navigable "$pos" 1)"
        render_menu_tui "$pos"
        ;;
      space)
        # Only toggle if row has items
        if [[ "${counts[$pos]}" -gt 0 ]]; then
          toggle_row "$pos"
          # Refresh sels array for render
          sels=("$sel_merged" "$sel_stale" "$sel_detached" "$sel_active")
          render_menu_tui "$pos"
        fi
        ;;
      enter)
        tput cnorm 2>/dev/null || true
        echo ""
        local selected_cats=()
        $sel_merged   && selected_cats+=(merged)
        $sel_stale    && selected_cats+=(stale)
        $sel_detached && selected_cats+=(detached)
        $sel_active   && selected_cats+=(active)

        if [[ "${#selected_cats[@]}" -eq 0 ]]; then
          echo -e "  ${DIM}Nothing selected. Use Space to toggle categories.${RESET}"
          tput civis 2>/dev/null || true
          render_menu_tui "$pos"
          continue
        fi

        local targets=()
        mapfile -t targets < <(paths_for_categories "${selected_cats[@]}")
        local total_sel="${#targets[@]}"
        local total_sz; total_sz="$(total_size_for_categories "${selected_cats[@]}")"

        echo ""
        echo -e "  About to remove ${BOLD}${total_sel}${RESET} worktree(s) across: ${BOLD}${selected_cats[*]}${RESET}  (~${total_sz})"
        echo ""
        read -r -p "  Proceed? [y/N] " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] || { echo "  Aborted."; exit 0; }
        echo ""
        remove_worktrees "${targets[@]}"
        return
        ;;
      i|I)
        tput cnorm 2>/dev/null || true
        echo ""
        fzf_individual
        return
        ;;
      q|Q)
        tput cnorm 2>/dev/null || true
        echo ""
        echo "  Bye."
        exit 0
        ;;
    esac
  done
}

fzf_individual() {
  local fzf_input=""
  for i in "${!WT_PATHS[@]}"; do
    local local_cat="${WT_CATEGORY[$i]}"
    [[ "$local_cat" == "main" ]] && continue
    local local_path="${WT_PATHS[$i]}"
    local local_branch="${WT_BRANCHES[$i]}"
    local local_date="${WT_LAST_DATE[$i]:-?}"
    local local_size="${WT_SIZE[$i]:-?}"
    local local_reason="${WT_REASON[$i]}"
    local tag
    case "$local_cat" in
      merged)   tag="[MERGED]  " ;;
      stale)    tag="[STALE]   " ;;
      detached) tag="[DETACHED]" ;;
      *)        tag="[ACTIVE]  " ;;
    esac
    fzf_input+="$(printf '%-9s  %-35s  %-12s  %-8s  %s\t%s' \
      "$tag" "$local_branch" "$local_date" "$local_size" "$local_reason" "$local_path")"$'\n'
  done

  if [[ -z "$fzf_input" ]]; then
    echo -e "  ${DIM}No worktrees available to select.${RESET}"
    return 1
  fi

  local -a selected
  mapfile -t selected < <(printf '%s' "$fzf_input" | fzf \
    --multi \
    --prompt="  Select worktrees to remove (Tab to toggle, Enter to confirm): " \
    --header="TAB=toggle  ENTER=confirm  ESC=cancel" \
    --color="hl:green,hl+:green" \
    --ansi \
    --delimiter=$'\t' \
    --with-nth=1 \
    --nth=1 \
    | cut -f2 \
  ) || true

  if [[ "${#selected[@]}" -eq 0 ]] || [[ -z "${selected[0]}" ]]; then
    echo "  No selection made. Aborted."
    exit 0
  fi

  echo ""
  echo -e "  Selected ${#selected[@]} worktree(s) for removal:"
  for p in "${selected[@]}"; do echo -e "    ${DIM}${p}${RESET}"; done
  echo ""
  read -r -p "  Proceed? [y/N] " confirm
  [[ "$confirm" =~ ^[Yy]$ ]] || { echo "  Aborted."; exit 0; }
  echo ""
  remove_worktrees "${selected[@]}"
}

tui_menu
