#!/usr/bin/env bash
# wtkill -- Interactive git worktree cleanup TUI
# Usage: wtkill [--dry-run] [--no-fetch] [--stale-days=N] [--help]

set -euo pipefail

if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
  echo "error: bash 4+ required (found ${BASH_VERSION})" >&2
  echo "  macOS: brew install bash" >&2
  exit 1
fi

VERSION="1.5.0" # x-release-please-version

# в”Ђв”Ђ Colours в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [[ -t 1 ]]; then
  RESET='\033[0m'
  BOLD='\033[1m'
  DIM='\033[2m'
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  BLUE='\033[0;34m'
  CYAN='\033[0;36m'
  WHITE='\033[0;37m'
  BOLD_GREEN='\033[1;32m'
  BOLD_YELLOW='\033[1;33m'
  BOLD_WHITE='\033[1;37m'
  BOLD_RED='\033[1;31m'
  BOLD_CYAN='\033[1;36m'
else
  # shellcheck disable=SC2034
  RESET='' BOLD='' DIM='' RED='' GREEN='' YELLOW='' BLUE='' CYAN='' WHITE=''
  BOLD_GREEN='' BOLD_YELLOW='' BOLD_WHITE='' BOLD_RED='' BOLD_CYAN=''
fi

# в”Ђв”Ђ Defaults в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
DRY_RUN=false
DO_FETCH=true
REPORT_ONLY=false
STALE_DAYS="${GIT_WT_CLEAN_STALE_DAYS:-14}"

# в”Ђв”Ђ Arg parsing в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
for arg in "$@"; do
  case "$arg" in
    --dry-run)       DRY_RUN=true ;;
    --no-fetch)      DO_FETCH=false ;;
    --report-only)   REPORT_ONLY=true ;;
    --stale-days=*)  STALE_DAYS="${arg#*=}" ;;
    --version|-V|-v)
      echo "wtkill ${VERSION}"
      exit 0
      ;;
    --update)
      REPO="mbensch/wtkill"
      LATEST=$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" | grep tag_name | cut -d'"' -f4)
      if [[ -z "$LATEST" ]]; then
        echo "error: could not determine latest release from GitHub" >&2
        exit 1
      fi
      LATEST_VER="${LATEST#v}"
      if [[ "$LATEST_VER" == "$VERSION" ]]; then
        echo "Already up to date (${VERSION})"
        exit 0
      fi
      SELF="$(realpath "$0")"
      echo "Updating wtkill ${VERSION} в†’ ${LATEST_VER}..."
      curl -fsSL "https://raw.githubusercontent.com/$REPO/$LATEST/wtkill" -o "$SELF"
      chmod +x "$SELF"
      echo "Done."
      exit 0
      ;;
    --help|-h)
      echo "Usage: wtkill [OPTIONS]"
      echo ""
      echo "Options:"
      echo "  --dry-run          Show what would be removed without deleting"
      echo "  --no-fetch         Skip git fetch --prune"
      echo "  --report-only      Print classification summary and exit (non-interactive)"
      echo "  --stale-days=N     Days of inactivity to mark as stale (default: 14)"
      echo "  --update           Update wtkill to the latest release"
      echo "  -v, --version      Show version and exit"
      echo "  --help             Show this help"
      echo ""
      echo "Environment:"
      echo "  GIT_WT_CLEAN_STALE_DAYS  Override default stale days"
      exit 0
      ;;
    *)
      echo "Unknown option: $arg" >&2
      exit 1
      ;;
  esac
done

# в”Ђв”Ђ Helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
die() { echo -e "${BOLD_RED}error:${RESET} $*" >&2; exit 1; }
info() { echo -e "${CYAN}  в†’${RESET} $*"; }
hr() { echo -e "${DIM}$(printf 'в”Ђ%.0s' {1..60})${RESET}"; }

# в”Ђв”Ђ Pre-flight checks в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
command -v git >/dev/null 2>&1 || die "git is not installed"
$REPORT_ONLY || command -v fzf >/dev/null 2>&1 || die "fzf is not installed (brew install fzf)"

git rev-parse --git-dir >/dev/null 2>&1 || die "Not inside a git repository"

GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || git rev-parse --git-dir)"
MAIN_WT="$(git rev-parse --show-toplevel 2>/dev/null || true)"

